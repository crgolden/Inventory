{
  "Serilog": {
    "MinimumLevel": {
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName"
    ]
  },
  "AllowedHosts": "*",
  "OpenIdConnectOptions": {
    "Authority": null,
    "ClientId": null,
    "ClientSecret": null,
    "ResponseType": "code",
    "ResponseMode": "query",
    "Scope": [
      "offline_access",
      "openid",
      "profile",
      "email",
      "phone",
      "address",
      "manuals",
      "products"
    ],
    "SaveTokens": true,
    "GetClaimsFromUserInfoEndpoint": true,
    "MapInboundClaims": false,
    "TokenValidationParameters": {
      "NameClaimType": "name",
      "RoleClaimType": "role"
    }
  },
  "AdminEmail": null,
  "AdminPassword": null,
  "SmokeBaseUrl": null
}
