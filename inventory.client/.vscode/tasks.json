  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "npm: start",
      "command": "npm",
      "args": ["start"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Changes detected",
          "endsPattern": "bundle generation (complete|failed)"
        }
      }
    },
    {
      "type": "shell",
      "label": "npm: test",
      "command": "npm",
      "args": ["test"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Changes detected",
          "endsPattern": "bundle generation (complete|failed)"
        }
      }
    }
  ]
}
